<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Chat Admin — Loop-Landing.com</title>
<link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="bg-slideshow">
  <div class="bg-slide" style="background-image:url('/img/jamesmarkosborne-code-1076536_1920.jpg')"></div>
  <div class="bg-slide" style="background-image:url('/img/fotis-fotopoulos-6sAl6aQ4OWI-unsplash.jpg')"></div>
  <div class="bg-slide" style="background-image:url('/img/pankaj-patel-Fi-GJaLRGKc-unsplash.jpg')"></div>
</div>
<canvas id="bg-canvas"></canvas>
<%- include('./partials/lp-header', { user: locals.user }) %>
<div class="container">

<h1 style="margin:40px 0 24px;">💬 Chat con clientes</h1>

<div style="display:grid;grid-template-columns:260px 1fr;gap:16px;height:520px;">
    <!-- Lista de clientes -->
    <div style="background:#111;border:1px solid rgba(255,255,255,0.07);border-radius:14px;overflow-y:auto;">
        <% users.forEach(function(u) { var unread = (chatMap[u.email]||[]).filter(function(m){return !m.readByAdmin;}).length; %>
            <div class="chat-user-item <%= activeEmail === u.email ? 'active' : '' %>"
                onclick="switchRoom('<%= u.email %>', '<%= u.name %>')"
                style="padding:14px 16px;cursor:pointer;border-bottom:1px solid rgba(255,255,255,0.04);
                    background:<%= activeEmail === u.email ? 'rgba(0,212,255,0.07)' : '' %>;
                    display:flex;justify-content:space-between;align-items:center;">
                <div>
                    <div style="font-weight:600;font-size:0.88rem;color:#fff;"><%= u.name %></div>
                    <div style="font-size:0.72rem;color:#444;"><%= u.email %></div>
                </div>
                <% if (unread > 0) { %>
                    <span class="notif-badge" style="position:static;display:inline-flex;"><%= unread %></span>
                <% } %>
            </div>
        <% }); %>
    </div>

    <!-- Ventana de chat -->
    <div style="display:flex;flex-direction:column;gap:12px;">
        <div id="chat-header" style="font-size:0.88rem;color:#555;padding:4px 0;">
            Seleccioná un cliente para ver la conversación
        </div>
        <div id="chat-box" style="flex:1;background:#111;border:1px solid rgba(255,255,255,0.07);border-radius:14px;overflow-y:auto;padding:16px;display:flex;flex-direction:column;gap:10px;"></div>
        <div style="display:flex;gap:10px;">
            <input type="text" id="msg-input" placeholder="Mensaje al cliente…"
                style="flex:1;padding:11px 16px;font-size:0.88rem;margin:0;"
                onkeydown="if(event.key==='Enter') sendMsg()">
            <button onclick="sendMsg()" style="width:auto;margin:0;padding:11px 20px;font-size:0.85rem;">Enviar</button>
        </div>
    </div>
</div>
</div>

<script src="/socket.io/socket.io.js"></script>
<script>
    var socket = io();
    var currentRoom = null;
    var allChats = <%- JSON.stringify(chatMap) %>;
    var adminEmail = 'garettjohan12@gmail.com';

    function switchRoom(email, name) {
        currentRoom = email;
        document.getElementById('chat-header').textContent = '💬 ' + name + ' · ' + email;
        var box = document.getElementById('chat-box');
        box.innerHTML = '';
        var msgs = allChats[email] || [];
        msgs.forEach(function(m) { appendMsg(m); });
        box.scrollTop = box.scrollHeight;
        socket.emit('join', email);
        fetch('/admin/chat/mark-read', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ email }) });
    }

    socket.on('message', function(msg) {
        if (msg.room !== currentRoom) return;
        appendMsg(msg);
        document.getElementById('chat-box').scrollTop = 99999;
    });

    function appendMsg(m) {
        var isAdmin = m.from === adminEmail;
        var box = document.getElementById('chat-box');
        box.innerHTML += '<div style="display:flex;flex-direction:column;align-items:' + (isAdmin ? 'flex-end' : 'flex-start') + '">'
            + '<div style="max-width:70%;padding:10px 14px;border-radius:12px;'
            + 'background:' + (isAdmin ? 'rgba(0,212,255,0.12)' : '#1a1a1a') + ';'
            + 'border:1px solid ' + (isAdmin ? 'rgba(0,212,255,0.25)' : 'rgba(255,255,255,0.07)') + ';'
            + 'color:' + (isAdmin ? '#00d4ff' : '#fff') + ';">'
            + '<p style="margin:0;font-size:0.88rem;line-height:1.5;">' + m.text + '</p>'
            + '<small style="color:#444;font-size:0.7rem;display:block;margin-top:4px;text-align:right;">' + m.time + '</small>'
            + '</div></div>';
    }

    function sendMsg() {
        if (!currentRoom) return;
        var input = document.getElementById('msg-input');
        var text = input.value.trim();
        if (!text) return;
        socket.emit('message', { room: currentRoom, text, fromAdmin: true });
        input.value = '';
    }
</script>
<script src="/js/particles.js"></script>
<%- include('./partials/lp-footer') %>
</body>
</html>
