    <div class="lp-estado-form">
      <input type="email" id="estadoEmail" placeholder="tu@email.com" class="lp-estado-input" autocomplete="email">
      <button onclick="consultarEstado()" class="lp-btn lp-btn-grad">Consultar →</button>
    </div>
    <div id="estadoResult" class="lp-estado-result" style="display:none;"></div>
  </div>
</section>

<div class="lp-hr lp-wrap"></div>

<!-- ════════════════════════════════════════
     FORMULARIO DE COTIZACIÓN
════════════════════════════════════════ -->
<section class="lp-section lp-wrap" id="cotizacion">
  <div class="lp-section-top reveal">
    <div>
      <p class="lp-label">CONTACTO</p>
      <h2 class="lp-section-title">¿Qué necesitas construir?</h2>
      <p style="color:rgba(200,230,255,0.55);margin:0 0 36px;font-size:0.97rem;max-width:560px;line-height:1.7;text-align:center;">
        Contanos tu idea y te respondemos en menos de <strong style="color:#00d4ff;">24 horas</strong> con una propuesta clara y sin compromisos.
      </p>
    </div>
  </div>

  <div id="quote-success" class="quote-success" style="display:none;">
    <div class="quote-success-icon">✓</div>
    <h3>¡Mensaje recibido!</h3>
    <p>Te contactaremos pronto. Mientras tanto podés ver nuestros trabajos.</p>
    <a href="/portafolio" class="lp-btn lp-btn-grad" style="margin-top:20px;display:inline-block;">Ver portafolio</a>
  </div>

  <form class="quote-form reveal" id="quote-form" action="/cotizacion" method="POST">
    <input type="text" name="website" style="display:none;position:absolute;left:-9999px;" tabindex="-1" autocomplete="off" aria-hidden="true">
    <div class="quote-row">
      <div class="quote-field"><label>Nombre completo</label><input type="text" name="name" placeholder="Tu nombre" required></div>
      <div class="quote-field"><label>WhatsApp</label><input type="tel" name="whatsapp" placeholder="+506 0000 0000" required pattern="[\+\d\s\-\(\)]{7,20}" title="Ingresá un número de WhatsApp válido (mín. 7 dígitos)"></div>
    </div>
    <div class="quote-row">
      <div class="quote-field"><label>Correo electrónico</label><input type="email" name="email" placeholder="tu@email.com" required></div>
      <div class="quote-field"><label>Tipo de servicio</label>
        <select name="service">
          <option value="Landing Page">Landing Page</option>
          <option value="Tienda Online">Tienda Online</option>
          <option value="Pagina Web">Página Web Corporativa</option>
          <option value="SaaS">Aplicación SaaS</option>
          <option value="Automatizacion">Automatización / IA</option>
          <option value="Otro">Otro</option>
        </select>
      </div>
    </div>
    <div class="quote-row">
      <div class="quote-field"><label>Presupuesto estimado</label>
        <select name="budget">
          <option value="$200 - $500">$200 – $500</option>
          <option value="$500 - $1000">$500 – $1,000</option>
          <option value="$1000 - $3000">$1,000 – $3,000</option>
          <option value="$3000+">$3,000+</option>
          <option value="No definido">No definido aún</option>
        </select>
      </div>
      <div class="quote-field"><label>¿Fecha límite?</label><input type="text" name="deadline" placeholder="Ej: 2 semanas, fin de mes…"></div>
    </div>
    <div class="quote-field" style="margin-top:16px;">
      <label>Descripción del proyecto</label>
      <textarea name="description" placeholder="Cuéntanos qué querés lograr con tu proyecto…" rows="4" required></textarea>
    </div>
    <button type="submit" class="quote-submit">Solicitar cotización →</button>
  </form>
</section>

<%- include('./partials/lp-footer') %>

<script>
  if (window.location.search.includes('ok=1')) {
    document.getElementById('quote-form').style.display = 'none';
    document.getElementById('quote-success').style.display = 'block';
  }

  function consultarEstado() {
    var email = document.getElementById('estadoEmail').value.trim();
    var result = document.getElementById('estadoResult');
    if (!email) {
      result.style.display = 'block';
      result.innerHTML = '<p class="lp-estado-error">Ingresá tu correo electrónico.</p>';
      return;
    }
    result.style.display = 'block';
    result.innerHTML = '<p class="lp-estado-loading">Consultando…</p>';
    fetch('/api/cotizacion/estado?email=' + encodeURIComponent(email))
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (!data.found) {
          result.innerHTML =
            '<p class="lp-estado-error">No encontramos una cotización con ese correo.<br>' +
            '<a href="#cotizacion" style="color:rgba(0,210,255,0.8);">¿Querés cotizar?</a></p>';
          return;
        }
        var steps = ['Nuevo', 'Contactado', 'Propuesta enviada', 'En negociación', 'Ganado'];
        var idx = steps.indexOf(data.status);
        if (idx === -1) idx = 0;
        var stepsHtml = steps.map(function(s, i) {
          var cls = i < idx ? 'done' : i === idx ? 'active' : 'pending';
          return '<div class="lp-step lp-step--' + cls + '">' +
            '<div class="lp-step-dot"></div>' +
            '<span>' + s + '</span>' +
            '</div>';
        }).join('<div class="lp-step-line"></div>');
        result.innerHTML =
          '<div class="lp-estado-card">' +
          '<div class="lp-estado-info">' +
          '<strong>' + escapeHtml(data.name) + '</strong>' +
          '<span>' + escapeHtml(data.service) + ' · ' + escapeHtml(data.date) + '</span>' +
          '<span class="lp-estado-id">' + escapeHtml(data.id) + '</span>' +
          '</div>' +
          '<div class="lp-steps">' + stepsHtml + '</div>' +
          '</div>';
      })
      .catch(function() {
        result.innerHTML = '<p class="lp-estado-error">Error al consultar. Intentá de nuevo.</p>';
      });
  }

  function escapeHtml(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  document.getElementById('estadoEmail').addEventListener('keydown', function(e) {
    if (e.key === 'Enter') consultarEstado();
  });
</script>
<script src="/js/particles.js"></script>
<script src="/js/interactions.js"></script>
<script src="/js/menu-toggle.js"></script>
</body>
</html>
