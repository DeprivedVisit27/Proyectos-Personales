<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Error - Mi Web Pro</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="bg-slideshow">
  <div class="bg-slide" style="background-image:url('/img/jamesmarkosborne-code-1076536_1920.jpg')"></div>
  <div class="bg-slide" style="background-image:url('/img/fotis-fotopoulos-6sAl6aQ4OWI-unsplash.jpg')"></div>
  <div class="bg-slide" style="background-image:url('/img/pankaj-patel-Fi-GJaLRGKc-unsplash.jpg')"></div>
</div>
    <canvas id="bg-canvas"></canvas>
<%- include('./partials/lp-header', { user: locals.user }) %>
    <div class="container" style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 80vh; text-align: center;">
        <div class="card" style="max-width: 500px; padding: 50px;">
            <h1 style="font-size: 80px; color: #00ffd5; margin-bottom: 10px;"><%= status %></h1>
            <h2 style="margin-bottom: 20px;"><%= title %></h2>
            <p style="margin-bottom: 30px; color: #aaa;"><%= message %></p>
            
            <div style="display: flex; gap: 15px; justify-content: center;">
                <a href="<%= link %>" class="primary-btn" style="margin: 0;"><%= linkText %></a>
                <% if (link !== '/') { %>
                    <a href="/" class="secondary-btn" style="margin: 0;">Ir al Inicio</a>
                <% } %>
            </div>
        </div>
    </div>
<script src="/js/particles.js"></script>
<%- include('./partials/lp-footer') %>
</body>
</html>