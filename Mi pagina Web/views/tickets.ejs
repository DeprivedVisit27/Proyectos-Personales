<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Soporte — Loop-Landing.com</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="bg-slideshow">
  <div class="bg-slide" style="background-image:url('/img/jamesmarkosborne-code-1076536_1920.jpg')"></div>
  <div class="bg-slide" style="background-image:url('/img/fotis-fotopoulos-6sAl6aQ4OWI-unsplash.jpg')"></div>
  <div class="bg-slide" style="background-image:url('/img/pankaj-patel-Fi-GJaLRGKc-unsplash.jpg')"></div>
</div>
<canvas id="bg-canvas"></canvas>
<%- include('./partials/lp-header', { user: locals.user }) %>
<div class="container">

    <h1 style="margin:40px 0 30px;">Centro de <span>Soporte</span></h1>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;align-items:start;">

        <!-- Nuevo ticket -->
        <div class="card">
            <h3 style="margin-bottom:20px;">Abrir nuevo ticket</h3>
            <form action="/tickets" method="POST">
                <input type="text" name="subject" placeholder="Asunto del problema" required style="margin-bottom:12px;">
                <textarea name="message" placeholder="Describe tu solicitud con detalle…" required
                    style="width:100%;background:rgba(255,255,255,0.04);border:1px solid rgba(0,212,255,0.16);border-radius:10px;padding:12px 14px;color:#e8f4ff;font-size:0.88rem;resize:vertical;min-height:100px;margin:0 0 14px;font-family:inherit;"></textarea>
                <button type="submit" style="width:auto;padding:10px 24px;">Enviar ticket</button>
            </form>
        </div>

        <!-- Mis tickets -->
        <div>
            <% if (!tickets || tickets.length === 0) { %>
                <div class="card" style="text-align:center;padding:40px;color:#555;">
                    <p>No tienes tickets aún.</p>
                </div>
            <% } else { %>
                <% tickets.slice().reverse().forEach(function(ticket) { %>
                    <%
                        var msgs = ticket.messages || [];
                        var isOpen = ticket.status === 'Abierto';
                        var hasUnread = msgs.some(function(m){ return m.from === 'admin' && !m.seenByUser; });
                    %>
                    <div class="card" style="margin-bottom:16px;border-color:<%= isOpen ? 'rgba(0,212,255,0.22)' : 'rgba(255,255,255,0.06)' %>;">

                        <!-- Cabecera del ticket -->
                        <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:14px;flex-wrap:wrap;gap:8px;">
                            <div>
                                <strong style="color:#fff;font-size:0.95rem;"><%= ticket.subject %></strong>
                                <small style="display:block;color:#555;margin-top:2px;font-family:monospace;"><%= ticket.id %> · <%= ticket.date %></small>
                            </div>
                            <span style="font-size:0.72rem;padding:3px 10px;border-radius:50px;white-space:nowrap;
                                background:<%= isOpen ? 'rgba(0,212,255,0.1)' : 'rgba(255,255,255,0.05)' %>;
                                border:1px solid <%= isOpen ? 'rgba(0,212,255,0.3)' : 'rgba(255,255,255,0.1)' %>;
                                color:<%= isOpen ? '#00d4ff' : '#555' %>;">
                                <%= ticket.status %>
                                <% if (hasUnread) { %> <span style="display:inline-block;width:6px;height:6px;background:#00d4ff;border-radius:50%;margin-left:4px;vertical-align:middle;"></span><% } %>
                            </span>
                        </div>

                        <!-- Hilo de mensajes -->
                        <div style="display:flex;flex-direction:column;gap:8px;margin-bottom:<%= isOpen ? '14px' : '0' %>;">
                            <% msgs.forEach(function(msg) { %>
                                <% var isUser = msg.from === 'user'; %>
                                <div style="display:flex;flex-direction:column;align-items:<%= isUser ? 'flex-end' : 'flex-start' %>;">
                                    <div style="max-width:85%;padding:10px 14px;border-radius:<%= isUser ? '14px 14px 4px 14px' : '14px 14px 14px 4px' %>;font-size:0.86rem;line-height:1.5;
                                        background:<%= isUser ? 'rgba(0,212,255,0.12)' : 'rgba(124,58,237,0.14)' %>;
                                        border:1px solid <%= isUser ? 'rgba(0,212,255,0.22)' : 'rgba(124,58,237,0.25)' %>;
                                        color:#e8f4ff;">
                                        <%= msg.text %>
                                    </div>
                                    <small style="color:#444;font-size:0.72rem;margin-top:3px;padding:0 4px;">
                                        <%= isUser ? 'Tú' : 'Soporte' %> · <%= msg.time %>
                                    </small>
                                </div>
                            <% }); %>
                        </div>

                        <!-- Responder (solo si abierto) -->
                        <% if (isOpen) { %>
                            <form action="/tickets/reply" method="POST" style="display:flex;gap:8px;align-items:flex-end;">
                                <input type="hidden" name="ticketId" value="<%= ticket.id %>">
                                <textarea name="message" placeholder="Escribe tu respuesta…" required
                                    style="flex:1;background:rgba(255,255,255,0.04);border:1px solid rgba(0,212,255,0.16);border-radius:10px;padding:10px 12px;color:#e8f4ff;font-size:0.84rem;resize:none;height:52px;font-family:inherit;margin:0;"></textarea>
                                <button type="submit" style="width:auto;margin:0;padding:10px 16px;font-size:0.82rem;border-radius:10px;white-space:nowrap;">Enviar</button>
                            </form>
                        <% } %>
                    </div>
                <% }); %>
            <% } %>
        </div>

    </div>
</div>
<script src="/js/particles.js"></script>
<%- include('./partials/lp-footer') %>
</body>
</html>
