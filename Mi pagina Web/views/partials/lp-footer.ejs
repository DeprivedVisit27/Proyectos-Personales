<script>
(function(){
  if(sessionStorage.getItem('ep')) return;
  var shown=false;
  function show(){
    if(shown||sessionStorage.getItem('ep')) return;
    shown=true;
    document.getElementById('exit-popup').style.display='flex';
    sessionStorage.setItem('ep','1');
  }
  document.addEventListener('mouseleave',function(e){ if(e.clientY<=0) setTimeout(show,150); });
  if(/Mobi|Android/i.test(navigator.userAgent)) setTimeout(show,35000);
  document.addEventListener('keydown',function(e){ if(e.key==='Escape') document.getElementById('exit-popup').style.display='none'; });
})();
</script>
