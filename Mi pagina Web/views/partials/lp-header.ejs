<script>
  (function () {
    // Greeting based on local time
    var el = document.getElementById('lp-greeting');
    if (el) {
      var h = new Date().getHours();
      var greet = h < 12 ? 'Buenos días' : h < 18 ? 'Buenas tardes' : 'Buenas noches';
      el.textContent = greet + ', ' + el.dataset.name;
    }

    // Hamburger dropdown
    document.addEventListener('DOMContentLoaded', function () {
      var btn  = document.getElementById('techBtn');
      var menu = document.getElementById('techMenu');
      var wrap = document.getElementById('techDropdown');
      if (!btn || !menu || !wrap) return;
      function openDD()  { menu.style.display = 'block'; wrap.classList.add('open'); }
      function closeDD() { menu.style.display = 'none';  wrap.classList.remove('open'); }
      btn.addEventListener('click', function (e) {
        e.stopPropagation();
        menu.style.display === 'block' ? closeDD() : openDD();
      });
      document.addEventListener('click', function (e) { if (!wrap.contains(e.target)) closeDD(); });
      document.addEventListener('keydown', function (e) { if (e.key === 'Escape') closeDD(); });
    });
  })();
</script>
