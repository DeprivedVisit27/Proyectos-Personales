<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Chat — Loop-Landing.com</title>
<link rel="stylesheet" href="/css/style.css">
</head>
<body class="dashboard-body">
<div class="bg-slideshow">
  <div class="bg-slide" style="background-image:url('/img/jamesmarkosborne-code-1076536_1920.jpg')"></div>
  <div class="bg-slide" style="background-image:url('/img/fotis-fotopoulos-6sAl6aQ4OWI-unsplash.jpg')"></div>
  <div class="bg-slide" style="background-image:url('/img/pankaj-patel-Fi-GJaLRGKc-unsplash.jpg')"></div>
</div>
<canvas id="bg-canvas"></canvas>
<%- include('./partials/lp-header', { user: locals.user }) %>
<div class="container" style="max-width:800px;">
    <h1 style="margin:40px 0 24px;">💬 Chat con soporte</h1>
    <div id="chat-box" style="background:#111;border:1px solid rgba(255,255,255,0.07);border-radius:14px;height:420px;overflow-y:auto;padding:20px;display:flex;flex-direction:column;gap:10px;margin-bottom:16px;">
        <% messages.forEach(function(m) { %>
            <div style="display:flex;flex-direction:column;align-items:<%= m.from === user.email ? 'flex-end' : 'flex-start' %>;">
                <div style="max-width:70%;padding:10px 14px;border-radius:12px;
                    background:<%= m.from === user.email ? 'rgba(0,212,255,0.12)' : '#1a1a1a' %>;
                    border:1px solid <%= m.from === user.email ? 'rgba(0,212,255,0.25)' : 'rgba(255,255,255,0.07)' %>;
                    color:<%= m.from === user.email ? '#00d4ff' : '#fff' %>;">
                    <p style="margin:0;font-size:0.9rem;line-height:1.5;"><%= m.text %></p>
                    <small style="color:#444;font-size:0.7rem;display:block;margin-top:4px;text-align:right;"><%= m.time %></small>
                </div>
            </div>
        <% }); %>
    </div>
    <div style="display:flex;gap:10px;">
        <input type="text" id="msg-input" placeholder="Escribe un mensaje…"
            style="flex:1;padding:12px 16px;font-size:0.9rem;margin:0;"
            onkeydown="if(event.key==='Enter') sendMsg()">
        <button onclick="sendMsg()" style="width:auto;margin:0;padding:12px 20px;">Enviar</button>
    </div>
</div>
<script src="/socket.io/socket.io.js"></script>
<script>
    const socket = io();
    const room   = '<%= userEmail %>';
    const myEmail = '<%= user.email %>';
    socket.emit('join', room);

    socket.on('message', function(msg) {
        const box = document.getElementById('chat-box');
        const isMe = msg.from === myEmail;
        box.innerHTML += `
            <div style="display:flex;flex-direction:column;align-items:${isMe ? 'flex-end' : 'flex-start'}">
                <div style="max-width:70%;padding:10px 14px;border-radius:12px;
                    background:${isMe ? 'rgba(0,212,255,0.12)' : '#1a1a1a'};
                    border:1px solid ${isMe ? 'rgba(0,212,255,0.25)' : 'rgba(255,255,255,0.07)'};
                    color:${isMe ? '#00d4ff' : '#fff'};">
                    <p style="margin:0;font-size:0.9rem;line-height:1.5;">${msg.text}</p>
                    <small style="color:#444;font-size:0.7rem;display:block;margin-top:4px;text-align:right;">${msg.time}</small>
                </div>
            </div>`;
        box.scrollTop = box.scrollHeight;
    });

    function sendMsg() {
        const input = document.getElementById('msg-input');
        const text  = input.value.trim();
        if (!text) return;
        socket.emit('message', { room, text });
        input.value = '';
    }

    document.getElementById('chat-box').scrollTop = 99999;
</script>
<script src="/js/particles.js"></script>
<%- include('./partials/lp-footer') %>
</body>
</html>
