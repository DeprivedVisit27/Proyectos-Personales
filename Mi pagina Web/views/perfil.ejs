<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mi Perfil - Mi Web Pro</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="bg-slideshow">
  <div class="bg-slide" style="background-image:url('/img/jamesmarkosborne-code-1076536_1920.jpg')"></div>
  <div class="bg-slide" style="background-image:url('/img/fotis-fotopoulos-6sAl6aQ4OWI-unsplash.jpg')"></div>
  <div class="bg-slide" style="background-image:url('/img/pankaj-patel-Fi-GJaLRGKc-unsplash.jpg')"></div>
</div>
    <canvas id="bg-canvas"></canvas>
<%- include('./partials/lp-header', { user: locals.user }) %>
    <div class="container">

        <div class="auth-container" style="max-width:600px;margin-top:60px;">
            <h1 style="margin-bottom:6px;">Mi <span style="color:#00ffd5;">Perfil</span></h1>
            <p style="color:#555;margin-bottom:25px;"><%= user.email %></p>

            <% if (saved) { %>
                <div style="background:rgba(0,255,213,0.08);border:1px solid rgba(0,255,213,0.3);padding:14px 18px;border-radius:12px;margin-bottom:20px;color:#00ffd5;">
                    ✓ Perfil actualizado correctamente
                </div>
            <% } %>
            <% if (error) { %>
                <div style="background:rgba(255,75,43,0.08);border:1px solid rgba(255,75,43,0.3);padding:14px 18px;border-radius:12px;margin-bottom:20px;color:#ff4b2b;">
                    ✕ <%= error %>
                </div>
            <% } %>

            <form action="/perfil" method="POST">
                <label style="color:#888;font-size:0.85rem;margin-top:15px;display:block;">Nombre</label>
                <input type="text" name="name" value="<%= user.name %>" required>

                <label style="color:#888;font-size:0.85rem;margin-top:15px;display:block;">Empresa</label>
                <input type="text" name="company" value="<%= user.company || '' %>">

                <label style="color:#888;font-size:0.85rem;margin-top:15px;display:block;">Tipo de proyecto</label>
                <input type="text" name="projectType" value="<%= user.projectType || '' %>">

                <label style="color:#888;font-size:0.85rem;margin-top:15px;display:block;">WhatsApp</label>
                <input type="text" name="whatsapp" value="<%= user.whatsapp || '' %>" placeholder="+506 0000 0000">

                <hr style="border-color:rgba(255,255,255,0.06);margin:25px 0;">
                <p style="color:#555;font-size:0.85rem;margin-bottom:5px;">Nueva contraseña (dejar en blanco para no cambiar, mínimo 6 caracteres)</p>
                <input type="password" name="newPassword" placeholder="••••••••">

                <button type="submit">Guardar cambios</button>
            </form>
        </div>
    </div>
<script src="/js/particles.js"></script>
<%- include('./partials/lp-footer') %>
</body>
</html>
